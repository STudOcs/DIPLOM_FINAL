{
  "raw_latex": "\\documentclass[paper=a4, fontsize=14pt, pagesize, DIV=calc, oneside]{scrreport}\n\n% 1. ЯЗЫК И ШРИФТЫ\n\\usepackage{metalogo}\n\\usepackage{polyglossia} \n\\setdefaultlanguage{russian} \n\\setotherlanguage{english} \n\\setmainfont{Times New Roman}\n\\newfontfamily\\cyrillicfont{Times New Roman}\n\\newfontfamily\\cyrillicfonttt{Courier New}\n\n% 2. ИНТЕРВАЛЫ И ГЕОМЕТРИЯ\n\\usepackage{setspace}\n\\usepackage[top=20mm, bottom=20mm, left=30mm, right=10mm, includefoot]{geometry}\n\\setlength{\\topskip}{0pt}\n\n% 3. ПАКЕТЫ\n\\usepackage[figure,table]{totalcount}\n\\usepackage{totcount}\n\\usepackage{totpages}\n\\usepackage{graphicx}\n\\usepackage{xcolor}\n\\usepackage{caption}\n\\usepackage{tabularx}\n\\usepackage{booktabs}\n\\usepackage[fleqn]{amsmath}\n\\usepackage{listings}\n\\usepackage{enumitem}\n\\usepackage{indentfirst} \n\\usepackage{tikz}\n\\usepackage{float}\n\n% 4. БИБЛИОГРАФИЯ\n\\usepackage[backend=biber, style=gost-numeric, sorting=none]{biblatex}\n\\addbibresource{mybibliography.bib}\n\n% 5. ПОДКЛЮЧАЕМ ВНЕШНИЕ ФАЙЛЫ (Основа стиля теперь тут)\n\\input{common.tex}\n\\input{dop.tex}\n\n% 6. ГИПЕРССЫЛКИ\n\\usepackage[colorlinks]{hyperref} \n\\hypersetup{colorlinks, linkcolor=black, urlcolor=black, citecolor=black}\n\n\\begin{document}\n\\pagestyle{empty} \n\n\\begin{titlepage}\n\t\\newgeometry{top=20mm, bottom=20mm, left=30mm, right=10mm}\n\t\\begin{center}\n\t\t\\begin{spacing}{0.7}\n\t\tМинистерство науки и высшего образования РФ\\\\\n\t\t{\\small Федеральное государственное автономное}\\\\\n\t\t{\\small образовательное учреждение высшего образования}\\\\\n\t\t\\textbf{\\small«СИБИРСКИЙ ФЕДЕРАЛЬНЫЙ УНИВЕРСИТЕТ»}\\\\\n\t\t\\end{spacing}\n\t\t\n\t\t\\vfill\n\t\t\n\t\t\\begin{spacing}{1.0}\n\t\tИНСТИТУТ КОСМИЧЕСКИХ И ИНФОРМАЦИОННЫХ ТЕХНОЛОГИЙ\\\\\n\t\tКафедра «ПРИКЛАДНАЯ ИТ»\\\\\n\t\t\\end{spacing}\n\t\t\n\t\t\\vfill\n\t\t\\vfill\n\t\t\n\t\t\\begin{spacing}{1.5}\n\t\t\t\\textbf{\\large ОТЧЕТ О ЛАБОРАТОРНОЙ РАБОТЕ №1}\\\\[5mm]\n\t\t\tПо дисциплине